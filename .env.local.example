# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored.

# ---- Supabase ----
# Dashboard → your project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google Maps Platform ----
# Browser key: restrict by HTTP referrer (localhost, *.vercel.app, prod domain).
# Enable: Maps JavaScript API, Places API (New) for client-side autocomplete.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# Optional: a custom Map ID for AdvancedMarker styling.
# Defaults to "DEMO_MAP_ID" — fine for dev, swap for a real one in prod via
# Google Cloud Console → Map Styles → New Map ID.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server key: restrict by API (Directions, Places API New, Distance Matrix).
GOOGLE_MAPS_SERVER_KEY=

# ---- Gemini (free tier) for editorial-cred rerank ----
# https://aistudio.google.com/ → Get API key
GOOGLE_GEMINI_API_KEY=

# ---- App ----
# In dev: http://localhost:3000. In prod: your deployed origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
